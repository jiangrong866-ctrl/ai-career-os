# Copy to .env on the production host.
# Use a fine-grained GitHub token with contents:write, pull_requests:write, issues:write.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/repo
GITHUB_BASE_BRANCH=main

# Optional future Drive service integration.
GOOGLE_APPLICATION_CREDENTIALS=
DRIVE_SYNC_DIR=
DRIVE_RCLONE_REMOTE=
ALERT_WEBHOOK_URL=
